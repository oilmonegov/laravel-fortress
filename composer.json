{
    "name": "chuxolab/laravel-fortress",
    "description": "1,755 engineering checks for secure, correct, auditable Laravel applications — with git hooks and merge protection",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "security",
        "audit",
        "checklist",
        "code-quality",
        "git-hooks",
        "merge-protection"
    ],
    "authors": [
        {
            "name": "Chux Okafor"
        }
    ],
    "homepage": "https://github.com/oilmonegov/laravel-fortress",
    "require": {
        "php": "^8.1",
        "symfony/finder": "^6.0 || ^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Fortress\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fortress\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fortress\\FortressServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint --test",
        "format": "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
