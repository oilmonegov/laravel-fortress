#!/bin/bash
# @fortress-hook v1.1.0
# applypatch-msg — Validates commit messages from git-am patches
#
# Reuses the same validation logic as commit-msg:
#   - Conventional commit format
#   - Message length limits
#   - WIP blocking on protected branches

set -euo pipefail

COMMIT_MSG_FILE="$1"

# Source the shared library
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_FILE="$HOOK_DIR/fortress-hook-lib.sh"
if [ ! -f "$LIB_FILE" ]; then
    PACKAGE_LIB="$(git rev-parse --show-toplevel 2>/dev/null)/vendor/chuxolab/laravel-fortress/hooks/fortress-hook-lib.sh"
    [ -f "$PACKAGE_LIB" ] && LIB_FILE="$PACKAGE_LIB"
fi
[ -f "$LIB_FILE" ] && source "$LIB_FILE" || {
    fortress_header() { echo "[Fortress] $1"; }
    fortress_pass() { echo "  ✓ $1"; }
    fortress_fail() { echo "  ✗ $1"; }
    fortress_warn() { echo "  ! $1"; }
    fortress_hook_enabled() { return 0; }
    fortress_config_get() { echo "$2"; }
    fortress_current_branch() { git rev-parse --abbrev-ref HEAD 2>/dev/null; }
    fortress_is_protected_branch() { local b; b=$(fortress_current_branch); echo "main master production" | grep -qw "$b"; }
}

if ! fortress_hook_enabled "applypatch_msg"; then
    exit 0
fi

fortress_header "applypatch-msg"

# Delegate to commit-msg hook if it exists
COMMIT_MSG_HOOK="$HOOK_DIR/commit-msg"
if [ -x "$COMMIT_MSG_HOOK" ]; then
    exec "$COMMIT_MSG_HOOK" "$COMMIT_MSG_FILE"
fi

# Fallback: basic validation
MSG=$(head -1 "$COMMIT_MSG_FILE")
ERRORS=0

MIN_LENGTH=$(fortress_config_get "min_length" "10")
if [ "${#MSG}" -lt "$MIN_LENGTH" ]; then
    fortress_fail "Patch commit message too short (${#MSG} chars < ${MIN_LENGTH} minimum)"
    ERRORS=$((ERRORS + 1))
fi

if [ "$ERRORS" -gt 0 ]; then
    exit 1
fi

fortress_pass "Patch message validated"
exit 0
